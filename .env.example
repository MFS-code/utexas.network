# Fine-grained or classic PAT with Issues (read/write) on the moderation repo.
# Labels join-request, pending, and project-request are created automatically if missing.
GITHUB_JOIN_BOT_TOKEN=replace-with-github-token
GITHUB_JOIN_REPO_OWNER=your-github-org-or-user
GITHUB_JOIN_REPO_NAME=your-repo-name

# Resend (https://resend.com): moderator alert on each submission; also used if GitHub issue creation fails.
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev
JOIN_ALERT_TO_EMAIL=moderators@your-domain.com

NEXT_PUBLIC_BASE_URL=https://your-site.example
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-client-id
